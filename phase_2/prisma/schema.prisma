// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Habit {
  id        Int       @id @default(autoincrement())
  name      String
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
  checkins  Checkin[] // one habit HAS MANY check-ins (virtual — not a column)
}

model Checkin {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  // the relation:
  habitId   Int                                              // the foreign key column (holds a Habit's id)
  habit     Habit    @relation(fields: [habitId], references: [id]) // tells Prisma: habitId → Habit.id
}
